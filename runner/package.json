  "type": "module",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');fs.mkdirSync('public',{recursive:true});const lsp='node_modules/@outblock/cadence-language-server/dist/';['cadence-language-server.wasm','worker.js','wasm_exec.js'].forEach(f=>{const t=f==='worker.js'?'public/cadence-lsp-worker.js':'public/'+f;try{fs.copyFileSync(lsp+f,t)}catch(e){console.warn('copy',f,e.message)}});try{fs.copyFileSync('node_modules/@trustwallet/wallet-core/dist/lib/wallet-core.wasm','public/wallet-core.wasm')}catch(e){console.warn('copy wallet-core.wasm',e.message)}\"",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
