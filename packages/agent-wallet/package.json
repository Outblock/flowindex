{
  "name": "@flowindex/agent-wallet",
  "version": "0.1.8",
  "description": "MCP server for Flow blockchain wallet — local keys, cloud wallet, passkey signing for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "flow-agent-wallet": "bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "codegen": "npx cadence-codegen typescript ./src/templates/cadence ./src/templates/cadence.gen.ts",
    "build": "bun run codegen && sed -i '' '/^export type number\\[\\]/d' src/templates/cadence.gen.ts && tsup",
    "dev": "tsup --watch",
    "start": "bun run src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@flowindex/flow-signer": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@onflow/fcl": "^1.21.9",
    "@onflow/rlp": "^1.2.2",
    "sha3": "^2.1.4",
    "viem": "^2.39.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@outblock/cadence-codegen": "^1.1.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@types/elliptic": "^6.4.18",
    "@types/node": "^25.3.5",
    "elliptic": "^6.6.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "nx": {
    "tags": [
      "package"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
